<launch>
    <let name="urdf_file" 
        value="$(find-pkg-share my_robot_description)/urdf/my_arm.urdf.xacro"/>
    <let name="rviz_config" 
        value="$(find-pkg-share my_robot_bringup)/config/config.rviz"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
            value="$(command 'xacro $(var urdf_file)')"/>
    </node>

    <node pkg="controller_manager" exec="ros2_control_node">
        <param name="robot_description"
            value="$(command 'xacro $(var urdf_file)')"/>
        <param from="$(find-pkg-share my_robot_bringup)/config/ros2_controllers.yaml"/>
    </node>

    <node pkg="controller_manager" exec="spawner" 
        args="joint_state_broadcaster --controller-manager /controller_manager"/>
    <node pkg="controller_manager" exec="spawner" 
        args="volvo_arm_controller --controller-manager /controller_manager"/>
    
    <include file="$(find-pkg-share volvo_moveit)/launch/move_group.launch.py"/>

  <node pkg="tf2_ros" exec="static_transform_publisher" name="camera_tf_publisher"
         args="--x 0.145 --y -0.085 --z 1.224
        --roll 3.1416 --pitch 0.0 --yaw 0.027
        --frame-id base_link
        --child-frame-id camera_frame"/>
            

    <node pkg="rviz2" exec="rviz2"
        args="-d $(var rviz_config)"
        output="screen"/>
         <!-- args="-d $(var rviz_config)" -->
</launch>
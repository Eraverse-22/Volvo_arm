<?xml version="1.0" encoding="utf-8"?>
<robot name="volvo_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
      <parent link="world"/>
      <child link="base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <xacro:include filename="$(find my_robot_description)/urdf/volvo_arm.ros2_control.xacro"/>


  <!-- Dummy world link — required because KDL cannot handle inertia on root link -->

